#!/bin/bash
# Pitchbox MCP server wrapper - forwards to the tsx-executed MCP server source.
# Spawned by an AgentRunner (locally over stdio, or relayed by the cloud runner)
# so the agent reaches Pitchbox data through MCP tools instead of CLI shell-outs.
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd -P)"
exec "$REPO_ROOT/node_modules/.bin/tsx" "$REPO_ROOT/cli/src/mcp/index.ts" "$@"
