# Pitchbox client stack (cloud edition) - copy to .env and fill in. Used by the
# docker-compose.app.* overlays. The compute runs on a separate cloud runner.

# --- database (inside the compose postgres, or your managed Postgres) -------
# Default points at the bundled `postgres` service. For the bundled DB, run the
# migrations once: docker compose ... exec web pnpm -F shared migrate
DATABASE_URL=postgresql://pitchbox:pitchbox@postgres:5432/pitchbox
# 32-byte hex key that encrypts account credentials at rest. REQUIRED.
ENCRYPTION_KEY=

# --- cloud runner the app dispatches to ------------------------------------
# wss:// (or ws://) URL of your Pitchbox cloud runner, and its bearer token.
PITCHBOX_RUNNER_URL=
PITCHBOX_RUNNER_TOKEN=

# --- auth (login gate for the dashboard) ------------------------------------
# When 'on', every route requires a logged-in user (see docs/orgs.md /
# docs/permissions.md); when 'off' (default), the dashboard has no login at all.
# REQUIRED: 'on' for any internet-facing deploy (a real domain, not localhost).
# scripts/deploy.sh refuses to deploy to a public PUBLIC_WEB_ORIGIN with this
# not set to 'on' (override with ALLOW_NO_AUTH=1, not recommended).
PITCHBOX_AUTH=off
# Public URL the dashboard is served at (used for the auth guard above and as
# adapter-node's ORIGIN for CSRF/form checks behind a reverse proxy).
PUBLIC_WEB_ORIGIN=https://pitchbox.app

# --- owner account bootstrap (used when PITCHBOX_AUTH=on) ------------------
# Seeds the owner account on a fresh deploy: `pitchbox seed:owner` runs right
# after migrations and creates this user through the same path the first-run
# login claim uses. No-op if a user already exists, either value is blank, or
# the values fail the login route's own validation (username 1-64 chars,
# letters/digits/"_"/"."/"-" only; password 8-256 chars). Leave both blank to
# claim the owner manually on first login instead.
PITCHBOX_OWNER_USERNAME=
PITCHBOX_OWNER_PASSWORD=

# --- web exposure ----------------------------------------------------------
WEB_PORT=5180
# Host address the web port is published on. 127.0.0.1 (behind a proxy) or 0.0.0.0.
APP_BIND=127.0.0.1

# --- image + limits (prod) -------------------------------------------------
# Repo name scripts/deploy.sh builds against. Each deploy mints its own
# immutable tag (<env>-<ref>-<timestamp>) off this repo and moves a
# <env>-latest alias onto it; only set a :tag here if you want to override the
# repo name, the tag portion is ignored by deploy.sh. To roll back manually:
#   APP_IMAGE=pitchbox-app:prod-v0.9.0-20260715120000 scripts/deploy.sh prod rollback --rollback
APP_IMAGE=pitchbox-app:latest
# `build` to build locally, `always` to pull from a registry.
APP_PULL_POLICY=build
# How many immutable per-env image tags / pre-migrate restore points
# scripts/deploy.sh keeps around after each successful deploy.
DEPLOY_KEEP_N=5
WEB_MEM_LIMIT=2g
WEB_CPU_LIMIT=2
DAEMON_MEM_LIMIT=512m
DAEMON_CPU_LIMIT=1

# --- cloudflared tunnel for the dashboard (prod, `--profile tunnel`) -------
# Route its hostname to http://web:${WEB_PORT} in the Cloudflare dashboard.
WEB_TUNNEL_TOKEN=
