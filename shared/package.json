{
  "name": "@pitchbox/shared",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./db": "./src/db/client.ts",
    "./db/schema": "./src/db/schema.ts",
    "./platforms/reddit": "./src/platforms/reddit/index.ts",
    "./platforms/reply-reader": "./src/platforms/base-reply-reader.ts",
    "./agents": "./src/agents/base.ts",
    "./agents/claude-code": "./src/agents/claude-code.ts",
    "./agents/registry": "./src/agents/registry.ts",
    "./crypto": "./src/crypto.ts",
    "./runlog": "./src/runlog/index.ts",
    "./runlog/types": "./src/runlog/types.ts",
    "./runlog/parsers": "./src/runlog/parsers/index.ts",
    "./runlog/parsers/claude-code": "./src/runlog/parsers/claude-code.ts",
    "./runlog/parsers/codex": "./src/runlog/parsers/codex.ts",
    "./runlog/parsers/opencode": "./src/runlog/parsers/opencode.ts"
  },
  "scripts": {
    "migrate": "tsx src/db/migrate.ts",
    "migrate:generate": "drizzle-kit generate",
    "seed:core": "tsx src/db/seed-core.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.13.0",
    "playwright": "^1.48.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0"
  }
}
