{
  "name": "pitchbox",
  "version": "0.10.6",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit -p shared && tsc --noEmit -p cli && tsc --noEmit -p daemon && pnpm -F @pitchbox/extension check && pnpm -F web check",
    "migrate": "pnpm -F shared migrate",
    "migrate:generate": "pnpm -F shared migrate:generate",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "dev": "bash scripts/dev.sh",
    "docker:dev": "bash scripts/docker-dev.sh",
    "dev:web": "pnpm -F web dev",
    "dev:extension": "pnpm -F @pitchbox/extension dev",
    "dev:docs": "pnpm run docs:dev",
    "migrate:from-ai-game": "tsx scripts/migrate-from-ai-game.ts",
    "seed:embertold": "tsx scripts/seed-embertold.ts",
    "reseed": "pnpm -F @pitchbox/shared seed:core && pnpm run seed:embertold",
    "build:extension": "pnpm -F @pitchbox/extension build",
    "zip:extension": "pnpm -F @pitchbox/extension zip",
    "docs:dev": "vitepress dev docs --port 5181",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "brand:render": "tsx scripts/render-brand.ts",
    "set-version": "node scripts/set-version.mjs",
    "version:check": "node scripts/set-version.mjs --check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "sharp": "0.35.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitepress": "^1.6.4",
    "vitest": "4.1.9"
  },
  "overrides": {
    "cookie": "^1.0.2",
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.0"
    },
    "@crxjs/vite-plugin": {
      "rollup": "^4.0.0"
    }
  }
}
