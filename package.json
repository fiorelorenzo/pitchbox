{
  "name": "pitchbox",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "shared",
    "cli",
    "web",
    "daemon"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc -b",
    "migrate": "npm run -w shared migrate",
    "migrate:generate": "npm run -w shared migrate:generate",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "dev": "npm run -w web dev",
    "migrate:from-ai-game": "tsx scripts/migrate-from-ai-game.ts",
    "seed:embertold": "tsx scripts/seed-embertold.ts",
    "reseed": "npm run -w @pitchbox/shared seed:core && npm run seed:embertold"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/node": "^22.19.17",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
