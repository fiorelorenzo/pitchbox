{
  "name": "pitchbox",
  "version": "0.4.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit -p shared && tsc --noEmit -p cli && tsc --noEmit -p daemon && pnpm -F @pitchbox/extension check && pnpm -F web check",
    "migrate": "pnpm -F shared migrate",
    "migrate:generate": "pnpm -F shared migrate:generate",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "dev": "concurrently -n web,ext,docs -c blue,magenta,green --kill-others-on-fail \"pnpm -F web dev\" \"pnpm -F @pitchbox/extension dev\" \"pnpm run docs:dev\"",
    "dev:web": "pnpm -F web dev",
    "dev:extension": "pnpm -F @pitchbox/extension dev",
    "dev:docs": "pnpm run docs:dev",
    "migrate:from-ai-game": "tsx scripts/migrate-from-ai-game.ts",
    "seed:embertold": "tsx scripts/seed-embertold.ts",
    "reseed": "pnpm -F @pitchbox/shared seed:core && pnpm run seed:embertold",
    "build:extension": "pnpm -F @pitchbox/extension build",
    "zip:extension": "pnpm -F @pitchbox/extension zip",
    "docs:dev": "vitepress dev docs --port 5181",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "brand:render": "tsx scripts/render-brand.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/node": "^22.19.17",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "sharp": "0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitepress": "^1.6.4",
    "vitest": "4.1.5"
  },
  "overrides": {
    "cookie": "^1.0.2",
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.0"
    },
    "@crxjs/vite-plugin": {
      "rollup": "^4.0.0"
    }
  }
}
