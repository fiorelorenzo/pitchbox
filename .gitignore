# Superpowers working files (per-user, not shared)
docs/superpowers/

# VitePress build output and cache
docs/.vitepress/dist/
docs/.vitepress/cache/

# Cloud-only code lives in private submodules wired in at build time.
# adapter and runner are tracked as git submodules (see .gitmodules); other
# cloud/* paths and node_modules inside the submodules stay ignored.
# Anchored to the repo root so nested OSS dirs named `cloud` (e.g. the
# cloud-runner protocol contract under shared/) are NOT ignored.
/cloud/*
!/cloud/adapter
!/cloud/runner
cloud/**/node_modules/
/private/

# Node
node_modules/
dist/
build/
.turbo/
*.tsbuildinfo

# Env
.env
.env.local
.env.*.local
!.env.example

# Logs
logs/
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Local-only seeds (user-specific, never committed)
scripts/seed-*.ts
!scripts/seed-*.ts.example

# Daemon runtime
daemon/logs/
daemon/run/

# Extension build artefacts
extension/dist/
extension/*.zip

# Web workspace
web/.svelte-kit/
web/build/
.claude/settings.local.json
shared/src/platforms/reddit/cache/
.claude/
daemon/tmp/
